<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/current_prayer_widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_shape"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header Section (App Name left, City on right) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="জান্নাত সন্ধান"
                android:textColor="#D4AF37"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/current_widget_status_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="পবিত্র ওয়াক্ত চলমান"
                android:textColor="#81C784"
                android:textSize="9.5sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/current_widget_city_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_sub_card_bg"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:text="ঢাকা"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- Main Current & Next Prayer Times block (like app) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_sub_card_bg"
        android:orientation="horizontal"
        android:padding="10dp"
        android:baselineAligned="false"
        android:layout_marginBottom="8dp">

        <!-- Current Prayer Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

            <FrameLayout
                android:layout_width="5dp"
                android:layout_height="5dp"
                android:layout_marginEnd="4dp"
                android:background="#4CAF50" />

                <TextView
                    android:id="@+id/current_widget_curr_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="চলমান ওয়াক্ত"
                    android:textColor="#B2DFDB"
                    android:textSize="9.5sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/current_widget_curr_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ফজর"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/current_widget_curr_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="০৪:০৫"
                    android:textColor="#E0E0E0"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Vertical Divider -->
        <FrameLayout
            android:layout_width="1dp"
            android:layout_height="35dp"
            android:layout_gravity="center_vertical"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:background="#30FFFFFF" />

        <!-- Next Prayer Section -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:gravity="end"
            android:orientation="vertical">

            <TextView
                android:id="@+id/current_widget_next_header"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="পরবর্তী ওয়াক্ত শুরু"
                android:textColor="#FFE082"
                android:textSize="9.5sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/current_widget_next_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="জোহর"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/current_widget_next_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:text="১২:০৬"
                    android:textColor="#D4AF37"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Countdown Progress Section (like app) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_sub_card_bg"
        android:orientation="vertical"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:text="পরবর্তী নামাজে বাকি:"
                android:textColor="#E0E0E0"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/current_widget_countdown_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:text="০ ঘণ্টা ৫৫ মিনিট"
                android:textColor="#D4AF37"
                android:textSize="10sp"
                android:textStyle="bold" />
        </RelativeLayout>

        <ProgressBar
            android:id="@+id/current_widget_progress_bar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="5dp"
            android:max="100"
            android:progress="60"
            android:progressTint="#D4AF37"
            android:progressBackgroundTint="#30FFFFFF" />
    </LinearLayout>

    <!-- Sehri & Iftar Cards Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2"
        android:layout_marginBottom="8dp">

        <!-- Sehri Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_sub_card_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌙"
                android:textSize="14sp"
                android:layout_marginEnd="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="সেহরির শেষ সময়"
                    android:textColor="#B0BEC5"
                    android:textSize="8.5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/current_widget_sehri_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="০৩:৫৫"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Iftar Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_sub_card_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☀️"
                android:textSize="14sp"
                android:layout_marginEnd="6dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ইফতারের সময়সূচী"
                    android:textColor="#B0BEC5"
                    android:textSize="8.5sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/current_widget_iftar_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="১৮:৪২"
                    android:textColor="#FFFFFF"
                    android:textSize="11sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Forbidden Time Card Panel -->
    <RelativeLayout
        android:id="@+id/current_widget_forbidden_banner_box"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@drawable/widget_sub_card_bg"
        android:padding="8dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:layout_toStartOf="@+id/current_widget_upcoming_forbidden_container"
            android:orientation="vertical">

            <TextView
                android:id="@+id/current_widget_forbidden_banner_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="আসন্ন নিষিদ্ধ নামাজের সময়সূচী"
                android:textColor="#FFB300"
                android:textSize="9.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/current_widget_forbidden_banner_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2.5dp"
                android:text="নামাজ আদায় করা সম্পূর্ণ নিষিদ্ধ"
                android:textColor="#E0E0E0"
                android:textSize="8.5sp" />
        </LinearLayout>

        <!-- Right side: Compact upcoming forbidden badge -->
        <LinearLayout
            android:id="@+id/current_widget_upcoming_forbidden_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_bg_shape"
            android:orientation="vertical"
            android:paddingLeft="6dp"
            android:paddingRight="6dp"
            android:paddingTop="3dp"
            android:paddingBottom="3dp"
            android:gravity="end">

            <TextView
                android:id="@+id/current_widget_upcoming_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="আসন্ন নিষিদ্ধ"
                android:textColor="#FF8A80"
                android:textSize="7.5sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/current_widget_upcoming_forbidden"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--:--"
                android:textColor="#FFFFFF"
                android:textSize="9sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

</LinearLayout>
