<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_shape"
    android:orientation="vertical"
    android:padding="12dp">

    <!-- Header Row (এক কোনায় থাকবে নাম আরেক কোনায় থাকবে সূর্যোদয় সূর্যাস্ত) -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <!-- Left corner: App Name / Active Waqt Title -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/widget_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="জান্নাত সন্ধান • ইবাদত"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_status_sub"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="পবিত্র ওয়াক্ত রানিং"
                android:textColor="#81C784"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Right corner: Sunrise / Sunset sequentially cycled -->
        <LinearLayout
            android:id="@+id/widget_sunrise_sunset_box"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/widget_sub_card_bg"
            android:orientation="vertical"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp">

            <TextView
                android:id="@+id/widget_cycle_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="সূর্যোদয়"
                android:textColor="#FFB300"
                android:textSize="9sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/widget_cycle_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:text="০৫:১৫ এএম"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Five daily waqt rows side-by-side -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:orientation="horizontal"
        android:weightSum="5">

        <!-- Fajr -->
        <LinearLayout
            android:id="@+id/widget_waqt_fajr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/widget_sub_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/fajr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ফজর"
                android:textColor="#D4AF37"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/fajr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৪:৩০"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Dhuhr -->
        <LinearLayout
            android:id="@+id/widget_waqt_dhuhr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/widget_sub_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/dhuhr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="যোহর"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/dhuhr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="১২:১৫"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Asr -->
        <LinearLayout
            android:id="@+id/widget_waqt_asr"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/widget_sub_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/asr_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="আসর"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/asr_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৪:১৫"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Maghrib -->
        <LinearLayout
            android:id="@+id/widget_waqt_maghrib"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/widget_sub_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/maghrib_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="মাগরিব"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/maghrib_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৬:৩০"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>

        <!-- Isha -->
        <LinearLayout
            android:id="@+id/widget_waqt_isha"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_margin="2dp"
            android:layout_weight="1"
            android:background="@drawable/widget_sub_card_bg"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingVertical="6dp">

            <TextView
                android:id="@+id/isha_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="এশা"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/isha_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="০৮:০০"
                android:textColor="#FFFFFF"
                android:textSize="9sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Forbidden Times Alert Banner on Bottom (আজকের নিষিদ্ধ নামাজের ৩টি সময়) -->
    <LinearLayout
        android:id="@+id/widget_forbidden_banner_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/widget_forbidden_bg"
        android:orientation="vertical"
        android:padding="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠️ নামাজের ৩টি নিষিদ্ধ সময়সূচী আজ:"
            android:textColor="#FF8A80"
            android:textSize="9.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_forbidden_details"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="সূর্যোদয়: ০৫:১০ - ০৫:২৫  |  দ্বিপ্রহর: ১২:১০ - ১২:২০  |  সূর্যাস্ত: ০৬:৪৫ - ০৭:০০"
            android:textColor="#FFEBEE"
            android:textSize="8.5sp"
            android:textStyle="normal" />
    </LinearLayout>

</LinearLayout>
